# ── Ambiente ──────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR

# ── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://hvac:hvac123@localhost:5432/hvac_db

# ── Segurança JWT ─────────────────────────────────────────────────────────────
SECRET_KEY=troque-por-chave-aleatoria-longa-minimo-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── CORS ──────────────────────────────────────────────────────────────────────
# Em produção: somente o domínio real. Em dev: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Microsoft Entra ID (Azure AD) ─────────────────────────────────────────────
# Obter em: portal.azure.com → App registrations
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_REDIRECT_URI=http://localhost:8000/api/auth/microsoft/callback

# ── Salesforce (deixar vazio até integração ser ativada) ──────────────────────
SF_INSTANCE_URL=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_SECURITY_TOKEN=
SF_API_VERSION=v59.0

# ── Redis (token blacklist + rate limiting) ───────────────────────────────────
# Em dev pode deixar vazio — usa fallback em memória
REDIS_URL=

# ── Infraestrutura cloud ──────────────────────────────────────────────────────
# Azure Container Apps / AWS App Runner preenchem automaticamente
PORT=8000
